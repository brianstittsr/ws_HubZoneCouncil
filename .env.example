# Environment Configuration
# Copy this file to .env.local and fill in your values

# Node Environment
NODE_ENV=development

# UserWay Accessibility Widget
# Get your account ID from https://userway.org/dashboard
NEXT_PUBLIC_USERWAY_ACCOUNT_ID=

# Firebase Configuration
# Get these values from Firebase Console > Project Settings > General > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Mattermost Integration
# Get webhook URL from Mattermost > Integrations > Incoming Webhooks
MATTERMOST_WEBHOOK_URL=

# ThomasNet Credentials (for authenticated supplier search)
# Create a free account at https://www.thomasnet.com/register
THOMASNET_EMAIL=
THOMASNET_PASSWORD=

# CONNEX Marketplace Credentials (MEP National Network supplier database)
# Create a free account at https://app.connexmarketplace.com/create-account
# 165,000+ U.S. manufacturers in the database
CONNEX_EMAIL=
CONNEX_PASSWORD=

# Microsoft Graph API Email (Azure AD)
# Used for sending signature requests, password resets, and contact form notifications
# Register an app at https://portal.azure.com > Azure Active Directory > App registrations
# Grant Mail.Send application permission and admin consent
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SMTP_FROM_NAME=Strategic Value+
SMTP_FROM_EMAIL=nelinia@strategicvalueplus.com

# Add additional environment variables below as needed
# NEXT_PUBLIC_* variables are exposed to the browser
# Variables without NEXT_PUBLIC_ prefix are server-side only

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# Stripe Configuration (for recurring billing)
# Get your API keys from https://dashboard.stripe.com/apikeys

# Test mode keys (sk_test_... / pk_test_...)
STRIPE_SECRET_KEY_TEST=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_TEST=pk_test_...

# Live mode keys (sk_live_... / pk_live_...)
STRIPE_SECRET_KEY_LIVE=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_...

# Legacy fallback (used if _TEST key is not set)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Webhook Secret (for webhook endpoint)
# Get this from https://dashboard.stripe.com/webhooks after creating a webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# SAM.gov API Key
# Register for a free API key at https://sam.gov/content/api-key-request
# Used for searching federal contract opportunities
SAM_API_KEY=
# SAM.gov Official Public API Key (FREE - required for opportunity search)
# Get your free key at: https://sam.gov > Account Details > Public API Key
SAM_GOV_API_KEY=your_sam_gov_api_key_here

# ─── Zenthium Data Center Referral Portal ────────────────────────────────────
# Email provider for referral notifications (SendGrid)
# Get API key from: https://app.sendgrid.com/settings/api_keys
ZENTHIUM_EMAIL_API_KEY=
ZENTHIUM_FROM_EMAIL=noreply@yourplatform.com

# Zoom API key for meeting creation
# Get from: https://marketplace.zoom.us/develop/create (Server-to-Server OAuth)
ZENTHIUM_ZOOM_API_KEY=
